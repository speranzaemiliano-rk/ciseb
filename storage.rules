rules_version = '2';

// Reglas de Firebase Storage — CISEB.
//
// ⚠️ Este archivo no existía en el repo hasta ahora: la seguridad real del
// bucket vivía (si vivía) únicamente en lo configurado a mano en la consola
// de Firebase, sin versionar. Este es un punto de partida que espeja la
// misma postura que ya tiene `database.rules.json` para Realtime Database
// (cualquier usuario autenticado puede leer/escribir — el control real de
// permisos por rol es solo de cliente, ver "Roles y permisos" en CLAUDE.md).
//
// ⚠️ NO se desplegó automáticamente. Antes de correr
// `firebase deploy --only storage`:
//   1. Revisar en la consola de Firebase (Storage → Rules) qué reglas están
//      activas HOY, para no romper nada que dependa de una configuración
//      distinta a la de acá.
//   2. Probar la subida/borrado de estudios (subirEstudioPaciente /
//      eliminarEstudioPaciente en index.html) contra estas reglas antes de
//      confiar en ellas en producción.
//
// Nota: el portal de carga externa (GET /estudios/subir, ver
// functions/server.js) NO depende de estas reglas — usa signed URLs
// generadas server-side con el Admin SDK, que se autorizan por firma
// criptográfica y no por estas reglas de cliente.
service firebase.storage {
  match /b/{bucket}/o {
    match /empresas/{empresaId}/proyectos/{proyectoId}/estudios/{pacienteId}/{archivo} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
